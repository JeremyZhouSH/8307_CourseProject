# ============================================================
# 项目环境变量配置模板
# 复制此文件为 .env 后填入实际值，程序启动时会自动加载
# ============================================================

# ----------------------------------------------------------
# LLM 配置（通过 SMART_LLM__* 前缀覆盖 config/default.yaml）
# ----------------------------------------------------------

# API 密钥（OpenAI / DeepSeek / 其他兼容服务商）
# SMART_LLM__API_KEY=sk-your-api-key-here

# 模型名称
# SMART_LLM__MODEL_NAME=deepseek-chat

# API 基础地址
# SMART_LLM__BASE_URL=https://api.deepseek.com/v1

# 提供商类型：openai_compatible / hf_local
# SMART_LLM__PROVIDER=openai_compatible

# 是否使用 Mock 模式（不调用真实 LLM，用于离线调试）
# 设为 true 时，LLM 返回 prompt 预览而非真实生成
# SMART_LLM__USE_MOCK=true

# ----------------------------------------------------------
# 备选：直接设置 OPENAI_API_KEY（兼容 LLMClient 默认读取）
# ----------------------------------------------------------
# OPENAI_API_KEY=sk-your-api-key-here

# ----------------------------------------------------------
# HuggingFace 配置（如需下载数据集或模型）
# ----------------------------------------------------------
# HF_TOKEN=hf_your-token-here
